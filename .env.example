# ─── Base de données (Supabase ou Neon) ──────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/ccelog?schema=public&sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/ccelog?schema=public"  # Pour les migrations Prisma

# ─── NextAuth v5 ──────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"  # URL publique en production

# ─── Microsoft Azure AD (SSO + Graph API) ────────────────────────────────────
# Depuis Azure App Registration ce94b85e-d038-4b49-8cf3-8e9df5f33b6c
AZURE_AD_CLIENT_ID="ce94b85e-d038-4b49-8cf3-8e9df5f33b6c"
AZURE_AD_CLIENT_SECRET="votre-secret-azure"          # expire 04/08/2028
AZURE_AD_TENANT_ID="c3e845fd-4d96-49d6-aeaf-409efb5ddbe5"

# ─── Microsoft Graph API ──────────────────────────────────────────────────────
M365_GRAPH_ENDPOINT="https://graph.microsoft.com/v1.0"
M365_ACCESS_TOKEN=""       # Token runtime (renouvelé automatiquement via OAuth)

# ─── WhatsApp Cloud API (Meta) ────────────────────────────────────────────────
WA_PHONE_NUMBER_ID=""      # ID du numéro WhatsApp Business
WA_API_TOKEN=""            # Token permanent Meta
WA_APP_SECRET=""           # Secret App pour vérification signature webhook
WA_VERIFY_TOKEN=""         # Token de vérification webhook (vous le choisissez)

# ─── Anthropic API ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Google Maps ──────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=""     # APIs: Distance Matrix + Geocoding

# ─── Redis (BullMQ) — Upstash ─────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
# En production Upstash :
# REDIS_URL="rediss://default:TOKEN@HOST.upstash.io:PORT"

# ─── Stockage fichiers (Supabase Storage ou Cloudflare R2) ───────────────────
STORAGE_PROVIDER="supabase"   # "supabase" | "r2"
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_KEY=""
# Pour R2 :
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME=""

# ─── MCP CCE LOG (Render) ─────────────────────────────────────────────────────
MCP_CCELOG_URL="https://ccelog-m365-mcp.onrender.com/mcp"

# ─── Observabilité ────────────────────────────────────────────────────────────
SENTRY_DSN=""
LOGTAIL_TOKEN=""

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV="development"
APP_URL="http://localhost:3000"
CRON_SECRET=""             # Secret pour déclencher les crons depuis Vercel
